{
  "name": "@alephium/mobile-wallet",
  "version": "2.5.1",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start --dev-client",
    "typecheck": "tsc --noEmit",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "analyze:android": "expo export --platform android && expo-atlas",
    "ios:device": "expo run:ios --device",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\" --log-level silent",
    "test": "vitest run",
    "prebuild": "expo prebuild && pnpm install:pods",
    "install:pods": "pnpm dlx pod-install",
    "clean": "rm -rf .turbo expo ios/build ios/Pods",
    "clean:node-modules": "rm -rf node_modules",
    "postinstall": "node -e \"process.exit(process.env.CI ? 0 : 1)\" || turbo build:deps",
    "eas-build-pre-install": "set -e; corepack enable && corepack prepare pnpm@9.4.0 --activate && pnpm -w install --frozen-lockfile && git -C \"$(git rev-parse --show-toplevel)\" diff --exit-code -- pnpm-lock.yaml",
    "eas-build-post-install": "turbo build:deps && node -e \"require.resolve('@alephium/wallet-dapp-provider/lib/provider.umd.json')\""
  },
