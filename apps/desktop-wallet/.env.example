VITE_USE_LOCAL_ANNOUNCEMENT_FILE=false # Turn this to true to use local announcement file for development
CROWDIN_PROJECT_ID=
CROWDIN_PERSONAL_TOKEN=

# Point a dev build at a throwaway PostHog project and actually emit events, so instrumentation can
# be verified end-to-end before shipping. Both default to production behaviour when unset.
VITE_POSTHOG_KEY=
VITE_POSTHOG_CAPTURE_IN_DEV=false
