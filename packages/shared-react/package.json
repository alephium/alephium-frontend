{
  "name": "@alephium/shared-react",
  "version": "0.0.3",
  "private": true,
  "main": "./src/index.tsx",
  "exports": {
    ".": "./src/index.tsx"
  },
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\" --log-level silent",
    "clean": "rm -rf .turbo",
    "clean:node-modules": "rm -rf node_modules",
    "lint": "eslint . --ext .ts --max-warnings=0",
    "lint:fix": "eslint . --fix --ext .ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@alephium/shared": "workspace:*",
    "@alephium/token-list": "^0.0.21",
    "@alephium/web3": "3.0.1",
    "@tanstack/react-query": "^5.81.2",
    "react": "^19.1.0",
    "react-redux": "^9.2.0"
  },
  "devDependencies": {
    "@alephium/eslint-config": "workspace:*",
    "@alephium/typescript-config": "workspace:*",
    "@alephium/walletconnect-provider": "3.0.1",
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2",
    "vitest": "^2.1.9"
  }
}
