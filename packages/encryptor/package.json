{
  "name": "@alephium/encryptor",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\" --log-level silent",
    "clean": "rm -rf .turbo coverage",
    "clean:node-modules": "rm -rf node_modules",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@metamask/browser-passworder": "^6.0.0"
  },
  "devDependencies": {
    "@alephium/eslint-config": "workspace:*",
    "@alephium/typescript-config": "workspace:*",
    "@types/node": "^22.0.0",
    "eslint": "^9.39.0",
    "tslib": "^2.3.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.0"
  }
}
