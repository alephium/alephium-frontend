{
  "name": "@alephium/wallet-dapp-provider",
  "version": "0.0.0",
  "private": true,
  "main": "lib/provider.cjs.js",
  "module": "lib/provider.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./lib/provider.js",
      "require": "./lib/provider.cjs.js"
    },
    "./lib/provider.umd.json": "./lib/provider.umd.json"
  },
  "files": [
    "lib",
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "watch-dev": "rollup -c -w",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\" --log-level silent",
    "clean": "rm -rf lib dist .turbo coverage",
    "clean:node-modules": "rm -rf node_modules",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@alephium/get-extension-wallet": "3.0.3",
    "@alephium/web3": "3.0.3"
  },
  "devDependencies": {
    "@alephium/eslint-config": "workspace:*",
    "@alephium/typescript-config": "workspace:*",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.0",
    "rollup": "^4.59.0",
    "rollup-plugin-dts": "^6.1.0",
    "rollup-plugin-esbuild": "^6.1.1",
    "tslib": "^2.3.1",
    "typescript": "~5.9.2"
  }
}
