{
  "name": "@alephium/shared-crypto",
  "version": "0.7.10",
  "private": true,
  "main": "dist/alephium.min.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/alephium.min.js"
    }
  },
  "scripts": {
    "lint": "eslint . --ext .ts --max-warnings=0",
    "lint:fix": "eslint . --fix --ext .ts",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "tsc --build . && webpack",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\" --log-level silent",
    "clean": "rm -rf dist .turbo coverage",
    "clean:node-modules": "rm -rf node_modules"
  },
  "devDependencies": {
    "@alephium/eslint-config": "workspace:*",
    "@alephium/typescript-config": "workspace:*",
    "@types/crypto-js": "^4.1.1",
    "@types/elliptic": "^6.4.18",
    "@types/node": "^20.14.0",
    "buffer": "^6.0.3",
    "crypto-browserify": "^3.12.0",
    "eslint": "^8.48.0",
    "path-browserify": "^1.0.1",
    "stream-browserify": "^3.0.0",
    "tslib": "^2.3.1",
    "typescript": "~5.9.2",
    "vitest": "^3.0.0",
    "webpack": "^5.104.1",
    "webpack-cli": "^5.1.4"
  }
}
