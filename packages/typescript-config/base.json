{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Default",
  "exclude": ["node_modules"],
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "skipLibCheck": true
  }
}
